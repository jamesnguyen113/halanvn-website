---
import Base from '../layouts/Base.astro';
import SeoCrossLinks from '../components/SeoCrossLinks.astro';
import { site } from '../data/site';

const faq = [
  {
    q: 'Tôn Nam Kim ở Hà Lan có phải hàng chính hãng không?',
    a: 'Có. Hà Lan nhập tôn cuộn Nam Kim trực tiếp từ nhà máy, đầy đủ chứng từ xuất xứ (CO/CQ). Tôn Nam Kim chính hãng có dòng in thương hiệu, độ dày và tiêu chuẩn trên bề mặt tấm — khách kiểm tra được ngay khi nhận hàng.',
  },
  {
    q: 'Giá tôn Nam Kim hôm nay bao nhiêu?',
    a: `Giá tôn Nam Kim thay đổi theo ngày, theo độ dày (0.35 — 0.50 mm), màu và kiểu sóng. Gọi ${site.hotline.display} đọc quy cách — nhà máy báo giá chính xác trong ngày, đã gồm VAT.`,
  },
  {
    q: 'Nên chọn tôn Nam Kim hay tôn Hoa Sen, Đông Á?',
    a: 'Cả ba đều là thương hiệu lớn, chất lượng ổn định. Nam Kim thường có giá cạnh tranh ở phân khúc tôn lạnh và tôn mạ màu; Hoa Sen mạnh về độ phủ thị trường; Đông Á cân bằng giá — chất lượng. Hà Lan phân phối cả ba nên bạn so sánh giá từng hãng trong một cuộc gọi.',
  },
  {
    q: 'Hà Lan cán được những sóng nào từ tôn Nam Kim?',
    a: 'Sóng 5 vuông, sóng 9 vuông, sóng 9 đôi, cliplock, sóng ngói, sóng vòm và lafông 13 sóng — cán đúng chiều dài mái tại 4 nhà máy Thủ Đức, Thuận An, Bình Chánh, Tây Ninh.',
  },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faq.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Trang chủ', item: new URL('/', Astro.site).href },
    { '@type': 'ListItem', position: 2, name: 'Tôn Nam Kim' },
  ],
};
---

<Base
  title="Tôn Nam Kim chính hãng — đại lý cán sóng, báo giá hôm nay | Hà Lan"
  description={`Mua tôn Nam Kim chính hãng: tôn lạnh, tôn mạ màu, tôn kẽm — cán sóng 5, 9, cliplock theo công trình tại TP.HCM, Bình Dương. Gọi ${site.hotline.display} báo giá tôn Nam Kim hôm nay.`}
  schema={[breadcrumbSchema, faqSchema]}
>
  <div class="bg-steel-950 py-10 text-white">
    <div class="mx-auto max-w-6xl px-4">
      <p class="eyebrow text-brand-soft">Thương hiệu phân phối</p>
      <h1 class="display mt-2 text-3xl sm:text-4xl">Tôn Nam Kim chính hãng</h1>
      <p class="mt-3 max-w-2xl text-sm leading-relaxed text-steel-300">
        Hà Lan nhập tôn cuộn Nam Kim trực tiếp từ nhà máy và cán sóng theo công trình của bạn —
        gọi <a href={`tel:${site.hotline.tel}`} class="font-bold text-white underline">{site.hotline.display}</a>
        để có giá tôn Nam Kim hôm nay.
      </p>
    </div>
  </div>

  <div class="mx-auto max-w-6xl px-4 py-10">
    <section class="max-w-3xl space-y-3 text-[0.95rem] leading-relaxed text-steel-800">
      <p>
        <strong>Tôn Nam Kim</strong> (Thép Nam Kim) là một trong ba thương hiệu tôn lớn nhất
        Việt Nam, nổi bật ở dòng tôn lạnh (mạ nhôm kẽm) và tôn mạ màu với lớp mạ đạt các tiêu
        chuẩn JIS và ASTM, xuất khẩu đi nhiều thị trường khó tính. Với công trình cần cân đối
        ngân sách mà vẫn muốn tôn thương hiệu, Nam Kim thường là lựa chọn có giá cạnh tranh.
      </p>
      <p>
        Hà Lan phân phối tôn Nam Kim song song với Hoa Sen, Đông Á, Pomina từ hơn 20 năm nay —
        bạn đọc quy cách một lần, nhận báo giá cả mấy hãng để so sánh. Tôn được
        <strong>cán sóng trực tiếp từ cuộn</strong> tại nhà máy gần công trình nhất trong 4 nhà máy
        Thủ Đức, Thuận An (Bình Dương), Bình Chánh, Tây Ninh: sóng 5, sóng 9, cliplock, sóng ngói,
        sóng vòm — cắt đúng chiều dài mái, không hao hụt, giao tận nơi, hóa đơn VAT.
      </p>
    </section>

    <div class="mt-10 border-l-4 border-brand bg-steel-50 p-5">
      <p class="display text-lg text-steel-950">Giá tôn Nam Kim theo ngày — gọi để chốt</p>
      <p class="mt-1 text-sm text-steel-700">
        Giá phụ thuộc độ dày, màu và kiểu sóng, thay đổi theo thị trường thép. Đọc quy cách qua
        điện thoại — báo giá chính xác trong ngày, đã gồm VAT.
      </p>
      <div class="mt-4 flex flex-wrap gap-3">
        <a
          href={`tel:${site.hotline.tel}`}
          class="display bg-brand px-5 py-3 text-sm tracking-widest text-white uppercase hover:bg-brand-hot"
        >
          {site.hotline.display}
        </a>
        <a
          href={site.zaloUrl}
          target="_blank"
          rel="noopener"
          class="display border border-steel-950 px-5 py-3 text-sm tracking-widest text-steel-950 uppercase hover:bg-steel-950 hover:text-white"
        >
          Nhắn Zalo
        </a>
      </div>
    </div>

    <section class="mt-12 max-w-3xl">
      <h2 class="display border-l-4 border-brand pl-3 text-xl text-steel-950">Câu hỏi thường gặp</h2>
      <div class="mt-4 space-y-5">
        {faq.map((f) => (
          <div>
            <h3 class="font-semibold text-steel-950">{f.q}</h3>
            <p class="mt-1 text-sm leading-relaxed text-steel-700">{f.a}</p>
          </div>
        ))}
      </div>
    </section>

    <SeoCrossLinks current="/ton-nam-kim/" />
  </div>
</Base>
