---
// Trang biến thể tôn Đông Á: /ton-dong-a/4-dem/, /ton-dong-a/cliplock/...
// Toàn bộ số giá đọc trực tiếp từ prices.ts qua dong-a-variants.ts.
import Base from '../../layouts/Base.astro';
import PriceTable from '../../components/PriceTable.astro';
import { site } from '../../data/site';
import { priceGroups, priceListUpdated } from '../../data/prices';
import { dongAVariants, type DongAVariant } from '../../data/dong-a-variants';

export function getStaticPaths() {
  return dongAVariants.map((v) => ({ params: { variant: v.slug }, props: { variant: v } }));
}

const { variant: v } = Astro.props as { variant: DongAVariant };
const groups = v.groupIds
  .map((id) => priceGroups.find((g) => g.id === id))
  .filter((g) => g !== undefined);
const siblings = dongAVariants.filter((s) => s.slug !== v.slug);

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: v.faq.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Trang chủ', item: new URL('/', Astro.site).href },
    { '@type': 'ListItem', position: 2, name: 'Tôn Đông Á', item: new URL('/ton-dong-a/', Astro.site).href },
    { '@type': 'ListItem', position: 3, name: v.name },
  ],
};

const productSchema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: v.name,
  description: v.description,
  brand: { '@type': 'Brand', name: 'Tôn Đông Á' },
  // No offers block: quote-by-phone business with no published per-product price.
  // Emitting an Offer without a price triggers GSC "Merchant listings" errors.
};
---

<Base title={v.title} description={v.description} schema={[breadcrumbSchema, faqSchema, productSchema]}>
  <div class="bg-steel-950 py-10 text-white">
    <div class="mx-auto max-w-4xl px-4">
      <nav class="text-xs text-steel-400" aria-label="Breadcrumb">
        <a href="/" class="hover:text-white">Trang chủ</a>
        <span aria-hidden="true"> / </span>
        <a href="/ton-dong-a/" class="hover:text-white">Tôn Đông Á</a>
        <span aria-hidden="true"> / </span>
        <span class="text-steel-300">{v.name}</span>
      </nav>
      <p class="eyebrow mt-3 text-brand-soft">Chính hãng Đông Á · Giá cập nhật {priceListUpdated}</p>
      <h1 class="display mt-2 text-3xl sm:text-4xl">Giá {v.name.charAt(0).toLowerCase() + v.name.slice(1)} hôm nay</h1>
      <p class="mt-3 max-w-2xl text-sm leading-relaxed text-steel-300">
        {v.callout}
        Gọi <a href={`tel:${site.hotline.tel}`} class="font-bold text-white underline">{site.hotline.display}</a>
        chốt giá theo số lượng.
      </p>
    </div>
  </div>

  <div class="mx-auto max-w-4xl px-4 py-10">
    <section class="max-w-3xl space-y-3 text-[0.95rem] leading-relaxed text-steel-800">
      {v.intro.map((p) => <p>{p}</p>)}
    </section>

    <div class="mt-10 space-y-10">
      {groups.map((g) => <PriceTable group={g} />)}
    </div>
    <p class="mt-3 text-xs text-steel-500">
      Đơn giá đ/m đã gồm VAT, cập nhật {priceListUpdated}. Giá có thể giảm theo số lượng — gọi hotline.
    </p>

    <div class="mt-10 border-l-4 border-brand bg-steel-50 p-5">
      <p class="display text-lg text-steel-950">Chốt giá hôm nay</p>
      <p class="mt-1 text-sm text-steel-700">
        Đọc độ dày, màu, kiểu sóng và số mét — nhà máy báo tổng tiền và lịch giao ngay.
      </p>
      <div class="mt-4 flex flex-wrap gap-3">
        <a
          href={`tel:${site.hotline.tel}`}
          class="display bg-brand px-5 py-3 text-sm tracking-widest text-white uppercase hover:bg-brand-hot"
        >
          {site.hotline.display}
        </a>
        <a
          href={site.zaloUrl}
          target="_blank"
          rel="noopener"
          class="display border border-steel-950 px-5 py-3 text-sm tracking-widest text-steel-950 uppercase hover:bg-steel-950 hover:text-white"
        >
          Nhắn Zalo
        </a>
      </div>
    </div>

    <section class="mt-12 max-w-3xl">
      <h2 class="display border-l-4 border-brand pl-3 text-xl text-steel-950">Câu hỏi thường gặp</h2>
      <div class="mt-4 space-y-5">
        {v.faq.map((f) => (
          <div>
            <h3 class="font-semibold text-steel-950">{f.q}</h3>
            <p class="mt-1 text-sm leading-relaxed text-steel-700">{f.a}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="mt-12 max-w-3xl">
      <h2 class="display border-l-4 border-brand pl-3 text-xl text-steel-950">Tôn Đông Á các loại khác</h2>
      <ul class="mt-3 flex flex-wrap gap-2 text-sm">
        {siblings.map((s) => (
          <li>
            <a
              href={`/ton-dong-a/${s.slug}/`}
              class="inline-block border border-steel-300 px-3 py-1.5 text-steel-800 hover:border-brand hover:text-brand"
            >
              {s.name}
            </a>
          </li>
        ))}
      </ul>
      <p class="mt-4 text-sm text-steel-700">
        Xem thêm: <a href="/ton-dong-a/" class="text-brand underline">tôn Đông Á — bảng giá đầy đủ</a> ·
        <a href="/bang-gia/ton-lop/" class="text-brand underline">bảng giá tôn lợp các hãng</a>
      </p>
    </section>
  </div>
</Base>
