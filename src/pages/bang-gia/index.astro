---
import Base from '../../layouts/Base.astro';
import PriceTable from '../../components/PriceTable.astro';
import { site } from '../../data/site';
import { priceGroups, priceNotes, priceListUpdated } from '../../data/prices';
---

<Base
  title={`Bảng giá tôn lợp, xà gồ hôm nay — cập nhật ${priceListUpdated} | Hà Lan`}
  description={`Bảng giá tôn mạ màu, tôn lạnh, tôn Đông Á, Pomina mới nhất, đã gồm VAT. Báo giá xà gồ C – Z theo quy cách. Gọi ${site.hotline.display} chốt giá trong ngày.`}
>
  <div class="bg-steel-950 py-10 text-white">
    <div class="mx-auto max-w-4xl px-4">
      <p class="eyebrow text-brand-soft">Cập nhật {priceListUpdated}</p>
      <h1 class="display mt-2 text-3xl sm:text-4xl">Bảng giá tôn lợp, xà gồ hôm nay</h1>
      <p class="mt-3 max-w-xl text-sm leading-relaxed text-steel-300">
        Giá tôn thép biến động theo thị trường. Bảng dưới là giá tham khảo —
        gọi <a href={`tel:${site.hotline.tel}`} class="font-bold text-white underline">{site.hotline.display}</a>
        để được báo giá chính xác trong ngày và chiết khấu theo số lượng.
      </p>
      <nav class="mt-5 flex flex-wrap gap-2" aria-label="Bảng giá theo nhóm">
        <a href="/bang-gia/ton-lop/" class="eyebrow border border-steel-600 px-3 py-2 text-steel-300 hover:border-white hover:text-white">
          Bảng giá tôn lợp
        </a>
        <a href="/bang-gia/xa-go/" class="eyebrow border border-steel-600 px-3 py-2 text-steel-300 hover:border-white hover:text-white">
          Bảng giá xà gồ C — Z
        </a>
      </nav>
    </div>
  </div>

  <div class="mx-auto max-w-4xl space-y-10 px-4 py-10">
    {priceGroups.map((g) => <PriceTable group={g} />)}

    <section class="border-l-4 border-brand bg-steel-50 p-5">
      <h2 class="display text-lg text-steel-950">Điều kiện áp dụng</h2>
      <ul class="mt-3 list-disc space-y-1.5 pl-5 text-sm text-steel-800">
        {priceNotes.map((n) => <li>{n}</li>)}
      </ul>
      <p class="mt-4 text-sm text-steel-700">{site.bank}</p>
      <a
        href={`tel:${site.hotline.tel}`}
        class="display mt-5 inline-block bg-brand px-6 py-3 text-sm tracking-widest text-white uppercase hover:bg-brand-hot"
      >
        Gọi chốt giá — {site.hotline.display}
      </a>
    </section>
  </div>
</Base>
