---
import Base from '../layouts/Base.astro';
import PriceTable from '../components/PriceTable.astro';
import { site } from '../data/site';
import { priceGroups, priceListUpdated } from '../data/prices';

// Đông Á có giá niêm yết trong bảng giá hiện hành — nhúng thẳng vào trang.
const dongAGroups = priceGroups.filter((g) => ['ton-mau-dong-a', 'ton-lanh-trang'].includes(g.id));

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Trang chủ', item: new URL('/', Astro.site).href },
    { '@type': 'ListItem', position: 2, name: 'Tôn Đông Á' },
  ],
};
---

<Base
  title={`Tôn Đông Á — bảng giá hôm nay ${priceListUpdated}, cán sóng theo công trình | Hà Lan`}
  description={`Mua tôn Đông Á chính hãng: tôn màu ĐA-S, ĐA-W và tôn lạnh AZ100 — giá niêm yết cập nhật ${priceListUpdated}, đã gồm VAT. Cán sóng theo công trình. Gọi ${site.hotline.display}.`}
  schema={[breadcrumbSchema]}
>
  <div class="bg-steel-950 py-10 text-white">
    <div class="mx-auto max-w-4xl px-4">
      <p class="eyebrow text-brand-soft">Thương hiệu phân phối · Giá cập nhật {priceListUpdated}</p>
      <h1 class="display mt-2 text-3xl sm:text-4xl">Tôn Đông Á — bảng giá hôm nay</h1>
      <p class="mt-3 max-w-2xl text-sm leading-relaxed text-steel-300">
        Tôn màu và tôn lạnh Đông Á chính hãng, cán sóng 5, 9, lafông, cliplock theo công trình.
        Gọi <a href={`tel:${site.hotline.tel}`} class="font-bold text-white underline">{site.hotline.display}</a>
        chốt giá theo số lượng.
      </p>
    </div>
  </div>

  <div class="mx-auto max-w-4xl px-4 py-10">
    <section class="max-w-3xl space-y-3 text-[0.95rem] leading-relaxed text-steel-800">
      <p>
        <strong>Tôn Đông Á</strong> là lựa chọn cân bằng giữa giá và chất lượng cho mái nhà ở và
        nhà xưởng: tôn màu dòng ĐA-S (tiết kiệm) và ĐA-W (bền màu hơn), tôn lạnh trắng AZ100
        chống ăn mòn cao. Hàng chính hãng có dòng in thương hiệu, độ dày và tiêu chuẩn trên bề mặt
        tấm tôn — kiểm tra được ngay khi nhận hàng, kèm hóa đơn VAT.
      </p>
      <p>
        Hà Lan cán tôn Đông Á từ cuộn tại 4 nhà máy Thủ Đức, Thuận An (Bình Dương), Bình Chánh,
        Tây Ninh: sóng 5, sóng 9, lafông 13 sóng, cliplock — cắt đúng chiều dài mái, giao tận
        công trình khu vực TP.HCM và miền Nam.
      </p>
    </section>

    <div class="mt-10 space-y-10">
      {dongAGroups.map((g) => <PriceTable group={g} />)}
    </div>
    <p class="mt-3 text-xs text-steel-500">
      Đơn giá đ/m đã gồm VAT, cập nhật {priceListUpdated}. Giá có thể giảm theo số lượng — gọi hotline.
    </p>

    <div class="mt-10 border-l-4 border-brand bg-steel-50 p-5">
      <p class="display text-lg text-steel-950">Chốt giá tôn Đông Á hôm nay</p>
      <p class="mt-1 text-sm text-steel-700">
        Đọc độ dày, màu, kiểu sóng và số mét — nhà máy báo tổng tiền và lịch giao ngay.
      </p>
      <div class="mt-4 flex flex-wrap gap-3">
        <a
          href={`tel:${site.hotline.tel}`}
          class="display bg-brand px-5 py-3 text-sm tracking-widest text-white uppercase hover:bg-brand-hot"
        >
          {site.hotline.display}
        </a>
        <a
          href={site.zaloUrl}
          target="_blank"
          rel="noopener"
          class="display border border-steel-950 px-5 py-3 text-sm tracking-widest text-steel-950 uppercase hover:bg-steel-950 hover:text-white"
        >
          Nhắn Zalo
        </a>
      </div>
    </div>

    <section class="mt-12 text-sm text-steel-700">
      <p>
        Xem thêm: <a href="/san-pham/ton-lop/" class="text-brand underline">tất cả sản phẩm tôn lợp</a> ·
        <a href="/bang-gia/ton-lop/" class="text-brand underline">bảng giá tôn hôm nay</a> ·
        <a href="/ton-hoa-sen/" class="text-brand underline">tôn Hoa Sen</a>
      </p>
    </section>
  </div>
</Base>
