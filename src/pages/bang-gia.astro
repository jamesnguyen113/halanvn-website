---
import Base from '../layouts/Base.astro';
import { site } from '../data/site';
import { priceGroups, priceNotes, priceListUpdated, fmtVnd } from '../data/prices';
---

<Base
  title="Bảng giá tôn lợp, xà gồ, cách nhiệt | Công ty Cổ phần Hà Lan"
  description="Bảng giá tham khảo tôn mạ màu nhập khẩu, tôn lạnh trắng, tôn màu Đông Á, Pomina, PE cách nhiệt và tôn nhựa sáng. Đã gồm VAT — gọi 0931 390 068 để chốt giá hôm nay."
>
  <div class="bg-steel-950 py-10 text-white">
    <div class="mx-auto max-w-4xl px-4">
      <p class="eyebrow text-brand-soft">Cập nhật {priceListUpdated}</p>
      <h1 class="display mt-2 text-3xl sm:text-4xl">Bảng giá tham khảo</h1>
      <p class="mt-3 max-w-xl text-sm leading-relaxed text-steel-300">
        Giá tôn thép biến động theo thị trường. Bảng dưới là giá tham khảo —
        gọi <a href={`tel:${site.hotline.tel}`} class="font-bold text-white underline">{site.hotline.display}</a>
        để được báo giá chính xác trong ngày và chiết khấu theo số lượng.
      </p>
    </div>
  </div>

  <div class="mx-auto max-w-4xl space-y-10 px-4 py-10">
    {priceGroups.map((g) => (
      <section>
        <h2 class="display border-l-4 border-brand pl-3 text-xl text-steel-950">{g.name}</h2>
        {g.note && <p class="mt-1 pl-4 text-sm text-steel-500">{g.note}</p>}
        <div class="mt-3 overflow-x-auto">
          <table class="w-full border-collapse text-sm">
            <thead>
              <tr class="bg-steel-950 text-left text-white">
                <th class="px-3 py-2.5 font-semibold">Quy cách</th>
                {g.rows.some((r) => r.weight) && <th class="px-3 py-2.5 font-semibold">Tỷ trọng (kg/md)</th>}
                <th class="px-3 py-2.5 text-right font-semibold">Đơn giá ({g.unit})</th>
              </tr>
            </thead>
            <tbody class="tabular">
              {g.rows.map((r, i) => (
                <tr class:list={[i % 2 ? 'bg-steel-50' : 'bg-white', 'border-b border-steel-200']}>
                  <td class="px-3 py-2.5">{r.spec}</td>
                  {g.rows.some((x) => x.weight) && <td class="px-3 py-2.5 text-steel-700">{r.weight ?? '—'}</td>}
                  <td class="px-3 py-2.5 text-right font-bold text-steel-950">
                    {r.price === null ? (
                      <a href={`tel:${site.hotline.tel}`} class="text-brand underline">Liên hệ</a>
                    ) : (
                      `${fmtVnd(r.price)} đ`
                    )}
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>
    ))}

    <section class="border-l-4 border-brand bg-steel-50 p-5">
      <h2 class="display text-lg text-steel-950">Điều kiện áp dụng</h2>
      <ul class="mt-3 list-disc space-y-1.5 pl-5 text-sm text-steel-800">
        {priceNotes.map((n) => <li>{n}</li>)}
      </ul>
      <p class="mt-4 text-sm text-steel-700">{site.bank}</p>
      <a
        href={`tel:${site.hotline.tel}`}
        class="display mt-5 inline-block bg-brand px-6 py-3 text-sm tracking-widest text-white uppercase hover:bg-brand-hot"
      >
        Gọi chốt giá — {site.hotline.display}
      </a>
    </section>
  </div>
</Base>
