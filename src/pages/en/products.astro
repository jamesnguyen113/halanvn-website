---
import Base from '../../layouts/Base.astro';
import { categories, byCategory } from '../../data/products';
---

<Base
  lang="en"
  title="Products — roofing sheets, purlins, insulated panels | Ha Lan Corporation"
  description="Full product range: galvanized and pre-painted steel sheets, 5/9-rib corrugated profiles, cliplock, C & Z purlins, PE/PU insulated sheets and construction steel."
>
  <div class="bg-steel-950 py-10 text-white">
    <div class="mx-auto max-w-6xl px-4">
      <h1 class="display text-3xl sm:text-4xl">Products</h1>
      <p class="mt-3 text-sm text-steel-300">
        Prices follow the daily steel market — call <a href="tel:0963199313" class="font-bold text-white underline">+84 963 199 313</a> for today's quote.
      </p>
    </div>
  </div>

  <div class="mx-auto max-w-6xl px-4 py-10">
    {categories.map((c) => (
      <section class="pt-10 first:pt-0">
        <h2 class="display border-l-4 border-brand pl-3 text-2xl text-steel-950">{c.nameEn}</h2>
        <div class="mt-5 grid grid-cols-2 gap-3 sm:gap-5 lg:grid-cols-4">
          {byCategory(c.slug).map((p) => (
            <div id={p.slug} class="flex scroll-mt-28 flex-col border border-steel-200 bg-white">
              <div class="aspect-[4/3] bg-steel-100">
                <img src={p.cover} alt={p.nameEn} class="h-full w-full object-cover" loading="lazy" width="400" height="300" />
              </div>
              <div class="p-4">
                <h3 class="display text-base text-steel-950">{p.nameEn}</h3>
                <p class="mt-1 text-xs text-steel-500">{p.name}</p>
              </div>
            </div>
          ))}
        </div>
      </section>
    ))}

    <p class="mt-12 border-l-4 border-brand bg-steel-50 p-5 text-sm text-steel-800">
      Detailed specifications are available in Vietnamese on each
      <a href="/san-pham/" class="font-semibold text-brand underline">product page</a>, or by
      email at <a href="mailto:halanvn@yahoo.com" class="font-semibold text-brand underline">halanvn@yahoo.com</a>.
    </p>
  </div>
</Base>
