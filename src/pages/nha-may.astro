---
import Base from '../layouts/Base.astro';
import { site, locations } from '../data/site';

const gallery = [
  { img: '/img/about/Nhamay.jpg', label: 'Nhà máy sản xuất' },
  { img: '/img/about/DSC00080.jpg', label: 'Khu vực cán sóng' },
  { img: '/img/about/DSC00081.jpg', label: 'Kho thành phẩm' },
  { img: '/img/about/Donggoi2.jpg', label: 'Đóng gói xuất xưởng' },
  { img: '/img/about/Donggoi5.jpg', label: 'Chuẩn bị giao hàng' },
  { img: '/img/about/Donggoi6.jpg', label: 'Xuất hàng lên xe' },
];
---

<Base
  title="Hệ thống 4 nhà máy — Thủ Đức, Thuận An, Bình Chánh, Tây Ninh | Hà Lan"
  description="4 nhà máy cán tôn, cắt xà gồ của Hà Lan tại TP.HCM, Bình Dương và Tây Ninh — nhận cán sóng theo quy cách, giao tận công trình."
>
  <div class="bg-steel-950 py-10 text-white">
    <div class="mx-auto max-w-6xl px-4">
      <p class="eyebrow text-brand-soft">Hệ thống sản xuất</p>
      <h1 class="display mt-2 text-3xl sm:text-4xl">4 nhà máy — cán tại xưởng gần công trình</h1>
      <p class="mt-3 max-w-xl text-sm text-steel-300">
        Đặt hàng qua hotline, nhà máy gần nhất cán và giao — rút ngắn thời gian chờ và phí vận chuyển.
      </p>
    </div>
  </div>

  <div class="mx-auto max-w-6xl px-4 py-10">
    <div class="grid gap-4 sm:grid-cols-2">
      {locations.map((l) => (
        <section class="border border-steel-200 p-5">
          <p class="eyebrow text-steel-500">{l.kind === 'office' ? 'Văn phòng' : 'Nhà máy'}</p>
          <h2 class="display mt-1 text-lg text-steel-950">{l.name}</h2>
          <p class="mt-2 text-sm text-steel-700">{l.address}</p>
          <ul class="tabular mt-3 space-y-1 text-sm">
            {l.phones.map((p) => (
              <li>
                <a href={`tel:${p.tel}`} class="font-semibold text-steel-900 hover:text-brand">{p.display}</a>
              </li>
            ))}
          </ul>
          <a
            href={`https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(l.mapQuery)}`}
            target="_blank"
            rel="noopener"
            class="eyebrow mt-4 inline-block text-brand hover:text-brand-dark"
          >
            Chỉ đường Google Maps →
          </a>
        </section>
      ))}
    </div>

    <section class="mt-12">
      <h2 class="display border-l-4 border-brand pl-3 text-xl text-steel-950">Hình ảnh nhà máy</h2>
      <div class="mt-6 grid grid-cols-2 gap-3 sm:grid-cols-3">
        {gallery.map((g) => (
          <figure>
            <img src={g.img} alt={g.label} class="aspect-[4/3] w-full border border-steel-200 object-cover" loading="lazy" />
            <figcaption class="mt-1.5 text-xs text-steel-500">{g.label}</figcaption>
          </figure>
        ))}
      </div>
    </section>

    <div class="mt-12 border-l-4 border-brand bg-steel-50 p-5">
      <p class="display text-lg text-steel-950">Cần cán theo quy cách riêng?</p>
      <p class="mt-1 text-sm text-steel-700">
        Gửi bản vẽ hoặc đọc quy cách qua điện thoại — nhà máy báo khối lượng và giá ngay.
      </p>
      <a
        href={`tel:${site.hotline.tel}`}
        class="display mt-4 inline-block bg-brand px-6 py-3 text-sm tracking-widest text-white uppercase hover:bg-brand-hot"
      >
        {site.hotline.display}
      </a>
    </div>
  </div>
</Base>
