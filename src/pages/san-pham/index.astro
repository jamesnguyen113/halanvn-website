---
import Base from '../../layouts/Base.astro';
import ProductCard from '../../components/ProductCard.astro';
import { categories, byCategory } from '../../data/products';
---

<Base
  title="Sản phẩm — Tôn lợp, xà gồ, tôn cách nhiệt, thép xây dựng | Hà Lan"
  description="Danh mục sản phẩm Hà Lan: tôn mạ kẽm, tôn mạ màu, tôn lạnh, tôn cán sóng 5 — 9, cliplock, xà gồ C — Z, tôn cách nhiệt PE/PU, phôi thép, sắt thép xây dựng."
>
  <div class="bg-steel-950 py-10 text-white">
    <div class="mx-auto max-w-6xl px-4">
      <p class="eyebrow text-brand-soft">Danh mục</p>
      <h1 class="display mt-2 text-3xl sm:text-4xl">Sản phẩm</h1>
      <p class="mt-3 max-w-xl text-sm text-steel-300">
        Tất cả sản phẩm cán và cắt theo quy cách công trình. Giá thay đổi theo ngày —
        gọi <a href="tel:0931390068" class="font-bold text-white underline">0931 390 068</a> để chốt giá.
      </p>
    </div>
  </div>

  <div class="mx-auto max-w-6xl px-4 py-10">
    <!-- Category jump nav -->
    <nav class="flex flex-wrap gap-2" aria-label="Danh mục sản phẩm">
      {categories.map((c) => (
        <a href={`#${c.slug}`} class="eyebrow border border-steel-300 px-3 py-2 text-steel-700 hover:border-brand hover:text-brand">
          {c.name}
        </a>
      ))}
    </nav>

    {categories.map((c) => (
      <section id={c.slug} class="scroll-mt-28 pt-12">
        <h2 class="display border-l-4 border-brand pl-3 text-2xl text-steel-950">{c.name}</h2>
        <p class="mt-2 max-w-2xl pl-4 text-sm text-steel-700">{c.blurb}</p>
        <div class="mt-6 grid grid-cols-2 gap-3 sm:gap-5 lg:grid-cols-4">
          {byCategory(c.slug).map((p) => <ProductCard product={p} />)}
        </div>
      </section>
    ))}
  </div>
</Base>
