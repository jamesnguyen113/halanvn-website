---
import Base from '../../layouts/Base.astro';
import ProductCard from '../../components/ProductCard.astro';
import { site } from '../../data/site';
import { products, categories, byCategory } from '../../data/products';

export function getStaticPaths() {
  return products.map((p) => ({ params: { slug: p.slug }, props: { product: p } }));
}

const { product } = Astro.props;
const category = categories.find((c) => c.slug === product.category)!;
const related = byCategory(product.category).filter((p) => p.slug !== product.slug).slice(0, 4);

// Per-product titles/descriptions: spec-flavored, unique, complete sentences
// (~135–155 ký tự) — không cắt cụt giữa chữ, không lặp một mẫu chung.
const seoOverrides: Record<string, { title: string; description: string }> = {
  'ton-ma-mau': {
    title: 'Tôn mạ màu — giá tốt từ nhà máy, cán sóng theo yêu cầu | Hà Lan',
    description: `Mua tôn mạ màu nhập khẩu và chính hãng Đông Á, Nam Kim — cán sóng 5, 9, cliplock theo công trình, giao tận nơi TP.HCM, Bình Dương. Gọi ${site.hotline.display}.`,
  },
  'ton-ma-kem': {
    title: 'Tôn mạ kẽm — cán sóng theo quy cách, giao tận công trình | Hà Lan',
    description: `Mua tôn mạ kẽm chính hãng, cán sóng 5, 9, cliplock theo quy cách. Giao tận nơi TP.HCM, Thủ Đức, Bình Dương. Gọi ${site.hotline.display} báo giá hôm nay.`,
  },
  'ton-lanh': {
    title: 'Tôn lạnh — chống ăn mòn, cán sóng theo yêu cầu | Hà Lan',
    description: `Mua tôn lạnh (mạ nhôm kẽm) Đông Á AZ100 và nhập khẩu — cán sóng theo công trình, giao tận nơi. Gọi ${site.hotline.display} chốt giá trong ngày.`,
  },
  'xa-go-thep-chu-c': {
    title: 'Xà gồ thép chữ C đen & mạ kẽm — báo giá theo quy cách | Hà Lan',
    description: `Mua xà gồ C đen, xà gồ C mạ kẽm cắt đúng quy cách công trình — sản xuất tại nhà máy Thủ Đức, Bình Dương. Gọi ${site.hotline.display} báo khối lượng và giá ngay.`,
  },
  'xa-go-thep-chu-z': {
    title: 'Xà gồ thép chữ Z đen & mạ kẽm — báo giá theo quy cách | Hà Lan',
    description: `Mua xà gồ Z đen, xà gồ Z mạ kẽm cắt đúng quy cách công trình — sản xuất tại nhà máy Thủ Đức, Bình Dương. Gọi ${site.hotline.display} báo khối lượng và giá ngay.`,
  },
  'ton-nhom': {
    title: 'Tôn nhôm — hợp kim 1050/1060/1100, dày 0,15 – 2,0 mm | Hà Lan',
    description: 'Tôn nhôm nhập khẩu 99% nhôm, khổ 1.000 – 1.219 mm, cán sóng 5, 7, 9 — nhẹ, chống ăn mòn, hợp nhà xưởng cao su, chế biến hải sản. Báo giá theo công trình.',
  },
  'ton-9-song-vuong': {
    title: 'Tôn 9 sóng vuông — sóng cao 21 mm, khổ cuộn 1.200 mm | Hà Lan',
    description: 'Tôn 9 sóng vuông cán từ cuộn 1.200 mm, thép nền G550, sóng cao 21 mm thoát nước nhanh — hợp mái nhà dân dụng và nhà xưởng. Cắt tấm theo chiều dài yêu cầu.',
  },
  'ton-9-song-doi-song-kep': {
    title: 'Tôn 9 sóng đôi (sóng kép) — tấm cứng vững hơn | Hà Lan',
    description: 'Tôn 9 sóng đôi có gân sóng kép giúp tấm cứng vững hơn tôn 9 sóng thường — dùng cho mái và vách nhà dân dụng, nhà xưởng. Cắt theo thiết kế, đủ bảng màu.',
  },
  'ton-5-song-vuong': {
    title: 'Tôn 5 sóng vuông — sóng cao 32 mm cho nhà xưởng | Hà Lan',
    description: 'Tôn 5 sóng vuông sóng cao 32 mm, dày 0,16 – 0,50 mm, thép nền G550 — thiết kế cho mái và vách nhà xưởng công nghiệp. Cán theo chiều dài, giao tận công trình.',
  },
  'ton-cliplock': {
    title: 'Tôn cliplock không vít — mái nhà xưởng hạn chế dột | Hà Lan',
    description: 'Tôn cliplock lợp bằng đai kẹp, không bắn vít xuyên tôn nên hạn chế tối đa dột tại lỗ vít — chuẩn cho mái nhà xưởng lớn. Cán theo chiều dài, báo giá theo quy cách.',
  },
  'ton-song-vom': {
    title: 'Tôn sóng vòm — uốn cong bán kính 250 mm đến 25 m | Hà Lan',
    description: 'Tôn sóng vòm uốn từ tôn sóng vuông theo bán kính 250 mm – 25 m tùy thiết kế — dùng cho mái vòm nhà xưởng, mái sảnh. Tư vấn quy cách và báo giá theo bản vẽ.',
  },
  'ton-song-ngoi': {
    title: 'Tôn sóng ngói — lợp mái biệt thự, nhẹ hơn ngói gạch | Hà Lan',
    description: 'Tôn sóng ngói cao 25 mm kiểu ngói tây, nhẹ hơn ngói gạch nhiều lần — giảm tải trọng khung mái cho biệt thự, mái dốc lớn. Đủ màu, cắt tấm theo kích thước mái.',
  },
  'ton-do-san': {
    title: 'Tôn đổ sàn — sóng cao 50 – 75 mm, khổ 870 – 1.000 mm | Hà Lan',
    description: 'Tôn đổ sàn sóng cao 50 – 75 mm, khổ hữu dụng 870 – 1.000 mm, dày 7,5 – 9,5 zem và 1,2 ly — đổ sàn bê tông showroom, nhà xưởng, nhà cao tầng thi công nhanh.',
  },
  'ton-cach-nhiet-pe': {
    title: 'Tôn cách nhiệt PE — lớp PE-OPP dày 3 – 10 mm | Hà Lan',
    description: 'Tôn sóng vuông cao 25 mm dán lớp cách nhiệt PE-OPP dày 3 – 10 mm — giảm nóng, giảm tiếng ồn cho mái nhà ở và nhà xưởng. Báo giá theo độ dày và khổ tôn.',
  },
  'ton-pu': {
    title: 'Tôn PU 3 lớp — lõi PU 18 mm cách nhiệt, cách âm | Hà Lan',
    description: 'Tôn PU sóng vuông 32 mm phủ lớp Polyurethane dày 18 mm — cách nhiệt, cách âm cho nhà ở, kho lạnh, phòng karaoke, nhà xưởng. Báo giá theo độ dày, số lượng.',
  },
  'tui-khi-cach-nhiet': {
    title: 'Túi khí cách nhiệt — màng nhôm phản xạ nhiệt, dày 4 mm | Hà Lan',
    description: 'Túi khí cách nhiệt màng nhôm dày 4 mm, khổ cuộn 1,22 – 1,55 m, dài 40 m — phản xạ nhiệt, cách âm cho mái tôn nhà ở và nhà xưởng. Giao nhanh TP.HCM, Bình Dương.',
  },
  'phoi-thep-ma-kem': {
    title: 'Phôi thép mạ kẽm xả băng — dày 1,5 / 1,8 / 2,0 mm | Hà Lan',
    description: 'Phôi thép mạ kẽm dạng cuộn xả băng theo khổ xà gồ, dày 1,5 / 1,8 / 2,0 mm, xuất xứ Nhật Bản, Trung Quốc — cấp cho xưởng cán xà gồ C, Z mạ kẽm số lượng lớn.',
  },
  'phoi-thep-den': {
    title: 'Phôi thép đen xả băng — dày 1,6 – 3,0 mm | Hà Lan',
    description: 'Phôi thép đen dạng cuộn xả băng theo khổ xà gồ, độ dày 1,6 – 3,0 mm, xuất xứ Nga, Trung Quốc — cấp cho xưởng gia công xà gồ C, Z đen số lượng lớn.',
  },
};

// Fallback cho sản phẩm mới chưa có override: không bao giờ cắt cụt giữa chữ.
const clip = (s: string, max = 155) =>
  s.length <= max ? s : s.slice(0, s.lastIndexOf(' ', max - 1)).replace(/[,;:.\s]+$/, '') + '…';
const seo = seoOverrides[product.slug] ?? {
  title: `${product.name} — báo giá trực tiếp từ nhà máy | Hà Lan`,
  description: clip(product.short) || `${product.name} — sản xuất và cung cấp bởi Công ty Cổ phần Hà Lan.`,
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Trang chủ', item: new URL('/', Astro.site).href },
    { '@type': 'ListItem', position: 2, name: 'Sản phẩm', item: new URL('/san-pham/', Astro.site).href },
    { '@type': 'ListItem', position: 3, name: category.name, item: new URL(`/san-pham/${category.slug}/`, Astro.site).href },
    { '@type': 'ListItem', position: 4, name: product.name },
  ],
};

// detail lines use a light markdown convention: "## " = heading, "- " = bullet.
type DetailBlock =
  | { t: 'h'; text: string }
  | { t: 'p'; text: string }
  | { t: 'ul'; items: string[] };
const detailBlocks: DetailBlock[] = [];
for (const line of product.detail) {
  if (line.startsWith('## ')) {
    detailBlocks.push({ t: 'h', text: line.slice(3) });
  } else if (line.startsWith('- ')) {
    const last = detailBlocks[detailBlocks.length - 1];
    if (last?.t === 'ul') last.items.push(line.slice(2));
    else detailBlocks.push({ t: 'ul', items: [line.slice(2)] });
  } else {
    detailBlocks.push({ t: 'p', text: line });
  }
}

const productSchema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: product.name,
  description: product.short,
  image: product.images.map((i) => new URL(i, Astro.site).href),
  brand: { '@type': 'Brand', name: 'Hà Lan' },
  // No offers block: quote-by-phone business with no published per-product price.
  // Emitting an Offer without a price triggers GSC "Merchant listings" errors.
};
---

<Base
  title={seo.title}
  description={seo.description}
  ogImage={product.cover}
  schema={[productSchema, breadcrumbSchema]}
>
  <nav class="mx-auto max-w-6xl px-4 pt-4 text-xs text-steel-500" aria-label="Breadcrumb">
    <a href="/" class="hover:text-brand">Trang chủ</a>
    <span aria-hidden="true"> / </span>
    <a href="/san-pham/" class="hover:text-brand">Sản phẩm</a>
    <span aria-hidden="true"> / </span>
    <a href={`/san-pham/${category.slug}/`} class="hover:text-brand">{category.name}</a>
  </nav>

  <article class="mx-auto max-w-6xl px-4 py-6">
    <div class="grid gap-8 lg:grid-cols-2">
      <!-- Gallery -->
      <div>
        <div class="aspect-[4/3] border border-steel-200 bg-steel-50">
          <img
            id="main-img"
            src={product.cover}
            alt={product.name}
            class="h-full w-full object-contain"
            width="600"
            height="450"
          />
        </div>
        {product.images.length > 1 && (
          <div class="mt-3 flex gap-2 overflow-x-auto">
            {product.images.map((img, i) => (
              <button
                class="thumb h-16 w-20 shrink-0 border border-steel-200 bg-white p-1 hover:border-brand"
                data-src={img}
                aria-label={`${product.name} — ảnh ${i + 1}`}
              >
                <img src={img} alt="" class="h-full w-full object-cover" loading="lazy" />
              </button>
            ))}
          </div>
        )}
      </div>

      <!-- Info -->
      <div>
        <p class="eyebrow text-brand">{category.name}</p>
        <h1 class="display mt-2 text-3xl text-steel-950 sm:text-4xl">{product.name}</h1>
        <p class="mt-4 leading-relaxed text-steel-700">{product.short}</p>

        {Object.keys(product.specs).length > 0 && (
          <dl class="mt-6 border-t border-steel-200">
            {Object.entries(product.specs).map(([k, v]) => (
              <div class="grid grid-cols-[7rem_1fr] gap-3 border-b border-steel-200 py-2.5 text-sm">
                <dt class="font-semibold text-steel-500">{k}</dt>
                <dd class="text-steel-900">{v}</dd>
              </div>
            ))}
          </dl>
        )}

        <div class="mt-8 border-l-4 border-brand bg-steel-50 p-5">
          <p class="display text-lg text-steel-950">Giá theo ngày — gọi để chốt</p>
          <p class="mt-1 text-sm text-steel-700">
            Giá tôn thép thay đổi theo thị trường. Gọi hotline để có giá tốt nhất hôm nay, đã gồm VAT.
          </p>
          <div class="mt-4 flex flex-wrap gap-3">
            <a
              href={`tel:${site.hotline.tel}`}
              class="display bg-brand px-5 py-3 text-sm tracking-widest text-white uppercase hover:bg-brand-hot"
            >
              {site.hotline.display}
            </a>
            <a
              href={site.zaloUrl}
              target="_blank"
              rel="noopener"
              class="display border border-steel-950 px-5 py-3 text-sm tracking-widest text-steel-950 uppercase hover:bg-steel-950 hover:text-white"
            >
              Nhắn Zalo
            </a>
          </div>
        </div>
      </div>
    </div>

    {product.detail.length > 0 && (
      <section class="mt-12 max-w-3xl">
        <h2 class="display border-l-4 border-brand pl-3 text-xl text-steel-950">Mô tả chi tiết</h2>
        <div class="mt-4 space-y-3 text-[0.95rem] leading-relaxed text-steel-800">
          {detailBlocks.map((b) =>
            b.t === 'h' ? (
              <h3 class="display pt-3 text-base text-steel-950">{b.text}</h3>
            ) : b.t === 'ul' ? (
              <ul class="list-disc space-y-1.5 pl-5 marker:text-brand">
                {b.items.map((item) => <li>{item}</li>)}
              </ul>
            ) : (
              <p>{b.text}</p>
            )
          )}
        </div>
      </section>
    )}

    {related.length > 0 && (
      <section class="mt-14">
        <h2 class="display text-xl text-steel-950">Sản phẩm cùng loại</h2>
        <div class="mt-5 grid grid-cols-2 gap-3 sm:gap-5 lg:grid-cols-4">
          {related.map((p) => <ProductCard product={p} />)}
        </div>
      </section>
    )}
  </article>
</Base>

<script>
  const main = document.getElementById('main-img') as HTMLImageElement | null;
  document.querySelectorAll<HTMLButtonElement>('.thumb').forEach((btn) => {
    btn.addEventListener('click', () => {
      if (main && btn.dataset.src) main.src = btn.dataset.src;
    });
  });
</script>
