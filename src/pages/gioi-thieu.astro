---
import Base from '../layouts/Base.astro';
import Corrugation from '../components/Corrugation.astro';
import { site } from '../data/site';

const awards = [
  { img: '/img/about/CupSPUyTin.gif', label: 'Cúp Sản phẩm uy tín' },
  { img: '/img/about/CupThuongHieuViet_2.gif', label: 'Cúp Thương hiệu Việt' },
  { img: '/img/about/CupTopTen.gif', label: 'Cúp Top Ten thương hiệu' },
];
const years = new Date().getFullYear() - site.founded;
---

<Base
  title="Giới thiệu Công ty Cổ phần Hà Lan — sản xuất tôn, xà gồ từ 2002"
  description={`Công ty Cổ phần Hà Lan thành lập năm ${site.founded}, sản xuất tôn lợp, xà gồ C — Z và phân phối thép xây dựng với 4 nhà máy tại TP.HCM, Bình Dương, Tây Ninh.`}
>
  <div class="bg-steel-950 py-10 text-white">
    <div class="mx-auto max-w-4xl px-4">
      <p class="eyebrow text-brand-soft">Từ {site.founded}</p>
      <h1 class="display mt-2 text-3xl sm:text-4xl">Giới thiệu công ty</h1>
    </div>
  </div>

  <article class="mx-auto max-w-4xl px-4 py-10">
    <div class="space-y-4 leading-relaxed text-steel-800">
      <p>
        <strong>{site.legalName}</strong> được thành lập năm {site.founded} tại TP. Hồ Chí Minh.
        Hơn {years} năm qua, Hà Lan tập trung vào một việc: sản xuất và cung cấp tôn lợp,
        xà gồ C — Z, sắt hộp và thép xây dựng đúng chủng loại, đúng độ dày, giao đúng hẹn.
      </p>
      <p>
        Chúng tôi vận hành 4 nhà máy tại Thủ Đức, Thuận An (Bình Dương), Bình Chánh và Tây Ninh,
        cán sóng và cắt xà gồ theo quy cách từng công trình. Sản phẩm dùng thép nền của các
        thương hiệu lớn — Hoa Sen, Đông Á, Nam Kim, POSCO — kèm chứng từ xuất xứ và hóa đơn VAT.
      </p>
      <p>
        Khách hàng của Hà Lan là nhà thầu xây dựng, cửa hàng vật liệu và chủ nhà khắp miền Nam.
        Phần lớn quay lại nhiều lần — vì giá báo qua điện thoại là giá giao tại công trình,
        không phát sinh.
      </p>
    </div>

    <section class="mt-12">
      <h2 class="display border-l-4 border-brand pl-3 text-xl text-steel-950">Thành tích thương hiệu</h2>
      <div class="mt-6 grid grid-cols-3 gap-4">
        {awards.map((a) => (
          <figure class="border border-steel-200 bg-white p-4 text-center">
            <img src={a.img} alt={a.label} class="mx-auto h-28 w-auto object-contain" loading="lazy" />
            <figcaption class="mt-3 text-xs font-semibold text-steel-700">{a.label}</figcaption>
          </figure>
        ))}
      </div>
    </section>

    <section class="mt-12">
      <h2 class="display border-l-4 border-brand pl-3 text-xl text-steel-950">Quy trình KCS</h2>
      <p class="mt-4 leading-relaxed text-steel-800">
        Mỗi lô hàng xuất xưởng đều qua kiểm tra độ dày, khổ rộng và bề mặt mạ theo tiêu chuẩn
        JIS G3302 / G3141 trước khi đóng gói. Hàng giao kèm phiếu quy cách để đối chiếu ngay
        tại công trình.
      </p>
      <div class="mt-6 grid grid-cols-2 gap-3 sm:grid-cols-3">
        {['/img/about/kcs_vn.jpg', '/img/about/Donggoi1.jpg', '/img/about/Donggoi3.jpg'].map((img) => (
          <img src={img} alt="Kiểm tra và đóng gói sản phẩm" class="aspect-[4/3] w-full border border-steel-200 object-cover" loading="lazy" />
        ))}
      </div>
    </section>

    <div class="mt-12">
      <Corrugation class="h-4 w-full text-steel-200" />
      <div class="mt-6 text-center">
        <a
          href="/nha-may/"
          class="display inline-block border border-steel-950 px-6 py-3 text-sm tracking-widest text-steel-950 uppercase hover:bg-steel-950 hover:text-white"
        >
          Xem hệ thống nhà máy →
        </a>
      </div>
    </div>
  </article>
</Base>
