---
import Base from '../layouts/Base.astro';
import { site, locations } from '../data/site';

const hq = locations.find((l) => l.kind === 'office')!;
---

<Base
  title="Liên hệ báo giá — Công ty Cổ phần Hà Lan"
  description={`Liên hệ Hà Lan: hotline ${site.hotline.display}, email ${site.email}. Trụ sở 358 Cộng Hòa, Tân Bình, TP.HCM và 4 nhà máy tại TP.HCM, Bình Dương, Tây Ninh.`}
  hreflang={{ vi: '/lien-he/', en: '/en/contact/' }}
>
  <div class="bg-steel-950 py-10 text-white">
    <div class="mx-auto max-w-6xl px-4">
      <p class="eyebrow text-brand-soft">Báo giá trong giờ làm việc</p>
      <h1 class="display mt-2 text-3xl sm:text-4xl">Liên hệ</h1>
      <p class="mt-3 text-sm text-steel-300">
        Nhanh nhất: gọi <a href={`tel:${site.hotline.tel}`} class="font-bold text-white underline">{site.hotline.display}</a>
        hoặc nhắn <a href={site.zaloUrl} target="_blank" rel="noopener" class="font-bold text-white underline">Zalo</a>.
      </p>
    </div>
  </div>

  <div class="mx-auto grid max-w-6xl gap-10 px-4 py-10 lg:grid-cols-2">
    <div>
      <h2 class="display border-l-4 border-brand pl-3 text-xl text-steel-950">Địa chỉ liên hệ</h2>
      <div class="mt-5 space-y-5">
        {locations.map((l) => (
          <div class="border-b border-steel-200 pb-4">
            <p class="display text-base text-steel-950">{l.name}</p>
            <p class="mt-1 text-sm text-steel-700">{l.address}</p>
            <p class="tabular mt-1 text-sm">
              {l.phones.map((p, i) => (
                <>
                  {i > 0 && <span class="text-steel-300"> · </span>}
                  <a href={`tel:${p.tel}`} class="font-semibold text-steel-900 hover:text-brand">{p.display}</a>
                </>
              ))}
            </p>
          </div>
        ))}
        <p class="text-sm">
          Email: <a href={`mailto:${site.email}`} class="font-semibold text-brand">{site.email}</a>
        </p>
      </div>

      <iframe
        title={`Bản đồ — ${hq.name}`}
        src={`https://www.google.com/maps?q=${encodeURIComponent(hq.mapQuery)}&output=embed`}
        class="mt-6 h-64 w-full border border-steel-200"
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
      ></iframe>
    </div>

    <div>
      <h2 class="display border-l-4 border-brand pl-3 text-xl text-steel-950">Nhận báo giá nhanh</h2>
      <div class="mt-5 border border-steel-200 bg-steel-50 p-6">
        <p class="text-sm leading-relaxed text-steel-700">
          Tôn và xà gồ C — Z báo giá theo quy cách từng công trình. Gọi hotline hoặc nhắn Zalo,
          nhà máy tính khối lượng và báo đơn giá <strong>ngay trong ngày</strong>.
        </p>

        <div class="mt-5 space-y-3">
          <a
            href={`tel:${site.hotline.tel}`}
            class="display flex items-center justify-center gap-2 bg-brand px-6 py-4 text-base tracking-widest text-white uppercase hover:bg-brand-hot"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M6.6 10.8a15.1 15.1 0 0 0 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C10.6 21 3 13.4 3 4c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.2.2 2.4.6 3.6.1.3 0 .7-.2 1l-2.3 2.2z" />
            </svg>
            Gọi {site.hotline.display}
          </a>
          <a
            href={site.zaloUrl}
            target="_blank"
            rel="noopener"
            class="display flex items-center justify-center gap-2 bg-[#0068ff] px-6 py-4 text-base tracking-widest text-white uppercase hover:brightness-110"
          >
            Nhắn Zalo báo giá
          </a>
        </div>

        <div class="mt-6 border-t border-steel-200 pt-5">
          <p class="text-sm font-semibold text-steel-800">Nhắn sẵn 4 thông tin để báo giá đúng:</p>
          <ul class="mt-2 space-y-1 text-sm text-steel-700">
            <li>• Chủng loại (tôn, hoặc xà gồ C — Z đen / mạ kẽm)</li>
            <li>• Độ dày và quy cách</li>
            <li>• Số lượng (mét, cây hoặc tấm)</li>
            <li>• Nơi giao hàng</li>
          </ul>
        </div>

        <p class="mt-5 text-xs text-steel-500">
          Tiếp nhận trong giờ làm việc. Đơn giá đã gồm VAT, có xe giao tận nơi.
        </p>
      </div>
    </div>
  </div>
</Base>
