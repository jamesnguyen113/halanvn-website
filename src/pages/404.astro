---
import Base from '../layouts/Base.astro';
import Corrugation from '../components/Corrugation.astro';
---

<Base
  title="Không tìm thấy trang | Công ty Cổ phần Hà Lan"
  description="Trang bạn tìm không tồn tại. Về trang chủ hoặc xem danh mục sản phẩm tôn, xà gồ, thép của Hà Lan."
  noindex
>
  <div class="mx-auto max-w-2xl px-4 py-20 text-center">
    <p class="display text-6xl text-steel-200">404</p>
    <h1 class="display mt-4 text-2xl text-steel-950">Không tìm thấy trang này</h1>
    <p class="mt-3 text-steel-700">Có thể đường dẫn đã thay đổi khi chúng tôi nâng cấp website.</p>
    <div class="mt-8 flex flex-wrap justify-center gap-3">
      <a href="/" class="display bg-brand px-6 py-3 text-sm tracking-widest text-white uppercase hover:bg-brand-hot">Trang chủ</a>
      <a href="/san-pham/" class="display border border-steel-950 px-6 py-3 text-sm tracking-widest text-steel-950 uppercase hover:bg-steel-950 hover:text-white">Sản phẩm</a>
    </div>
    <div class="mt-12"><Corrugation class="h-4 w-full text-steel-200" /></div>
  </div>
</Base>
