---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { site } from '../../data/site';

const posts = (await getCollection('tin-tuc')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const fmtDate = new Intl.DateTimeFormat('vi-VN', {
  day: '2-digit',
  month: '2-digit',
  year: 'numeric',
});

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Trang chủ', item: new URL('/', Astro.site).href },
    { '@type': 'ListItem', position: 2, name: 'Tin tức' },
  ],
};
---

<Base
  title="Tin tức & tư vấn tôn thép — chọn tôn, tính mái, giá cả | Hà Lan"
  description={`Tư vấn thực tế từ nhà máy tôn thép Hà Lan: cách tính tôn lợp mái, chọn tôn cách nhiệt, so sánh các loại sóng và thương hiệu. Hỏi nhanh qua ${site.hotline.display}.`}
  schema={[breadcrumbSchema]}
>
  <div class="bg-steel-950 py-10 text-white">
    <div class="mx-auto max-w-4xl px-4">
      <nav class="text-xs text-steel-400" aria-label="Breadcrumb">
        <a href="/" class="hover:text-white">Trang chủ</a>
        <span aria-hidden="true"> / </span>
        <span class="text-steel-300">Tin tức</span>
      </nav>
      <h1 class="display mt-3 text-3xl sm:text-4xl">Tin tức & tư vấn</h1>
      <p class="mt-3 max-w-2xl text-sm leading-relaxed text-steel-300">
        Kinh nghiệm thực tế từ nhà máy: cách tính tôn cho mái, chọn loại tôn và xà gồ phù hợp
        từng công trình, cập nhật giá cả thị trường.
      </p>
    </div>
  </div>

  <div class="mx-auto max-w-4xl px-4 py-10">
    <div class="space-y-6">
      {posts.map((p) => (
        <article class="border border-steel-200 p-5 transition-colors hover:border-brand">
          <p class="text-xs text-steel-500">
            <time datetime={p.data.date.toISOString().slice(0, 10)}>{fmtDate.format(p.data.date)}</time>
          </p>
          <h2 class="display mt-1.5 text-xl text-steel-950">
            <a href={`/tin-tuc/${p.id}/`} class="hover:text-brand">{p.data.title}</a>
          </h2>
          <p class="mt-2 text-sm leading-relaxed text-steel-700">{p.data.description}</p>
          <a href={`/tin-tuc/${p.id}/`} class="mt-3 inline-block text-sm font-semibold text-brand underline">
            Đọc tiếp →
          </a>
        </article>
      ))}
    </div>

    <div class="mt-12 border-l-4 border-brand bg-steel-50 p-5">
      <p class="display text-lg text-steel-950">Cần tư vấn riêng cho công trình của bạn?</p>
      <p class="mt-1 text-sm text-steel-700">
        Đọc loại công trình và kích thước — nhà máy tư vấn loại tôn, xà gồ phù hợp và báo giá ngay.
      </p>
      <div class="mt-4 flex flex-wrap gap-3">
        <a
          href={`tel:${site.hotline.tel}`}
          class="display bg-brand px-5 py-3 text-sm tracking-widest text-white uppercase hover:bg-brand-hot"
        >
          {site.hotline.display}
        </a>
        <a
          href={site.zaloUrl}
          target="_blank"
          rel="noopener"
          class="display border border-steel-950 px-5 py-3 text-sm tracking-widest text-steel-950 uppercase hover:bg-steel-950 hover:text-white"
        >
          Nhắn Zalo
        </a>
      </div>
    </div>
  </div>
</Base>
