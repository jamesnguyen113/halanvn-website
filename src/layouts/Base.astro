---
import '@fontsource/be-vietnam-pro/400.css';
import '@fontsource/be-vietnam-pro/500.css';
import '@fontsource/be-vietnam-pro/700.css';
import '@fontsource-variable/archivo';
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import MobileCTA from '../components/MobileCTA.astro';
import { site, locations } from '../data/site';

interface Props {
  title: string;
  description: string;
  lang?: string;
  ogImage?: string;
  /** Extra JSON-LD blocks (e.g. Product on product pages) */
  schema?: object[];
  /** vi/en alternates for pages that exist in both languages (x-default → vi) */
  hreflang?: { vi: string; en: string };
  noChrome?: boolean;
  /** Trang tiện ích (404, cảm ơn) — không cho index */
  noindex?: boolean;
}

const {
  title,
  description,
  lang = 'vi',
  ogImage = '/img/logo.png',
  schema = [],
  hreflang,
  noChrome = false,
  noindex = false,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);
const isHome = Astro.url.pathname === '/';

// Số hotline (khác số nhà máy) — phân loại event click_hotline / click_factory_phone
const hotlineTels = site.phones.filter((p) => p.label.startsWith('Hotline')).map((p) => p.tel);

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: site.shortName,
  alternateName: site.name,
  url: site.domain,
  inLanguage: 'vi',
};

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: site.name,
  legalName: site.legalName,
  url: site.domain,
  logo: `${site.domain}/img/logo.png`,
  foundingDate: String(site.founded),
  email: site.email,
  telephone: '+84' + site.hotline.tel.slice(1),
  address: {
    '@type': 'PostalAddress',
    streetAddress: '358 Cộng Hòa, Phường 13, Quận Tân Bình',
    addressLocality: 'TP. Hồ Chí Minh',
    addressCountry: 'VN',
  },
  department: locations
    .filter((l) => l.kind === 'factory')
    .map((l) => ({
      '@type': 'LocalBusiness',
      name: l.name,
      telephone: '+84' + l.phones[0].tel.slice(1),
      address: { '@type': 'PostalAddress', streetAddress: l.address, addressCountry: 'VN' },
    })),
};
---

<!doctype html>
<html {lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex ? <meta name="robots" content="noindex, follow" /> : <link rel="canonical" href={canonical} />}
    {hreflang && (
      <>
        <link rel="alternate" hreflang="vi" href={new URL(hreflang.vi, Astro.site)} />
        <link rel="alternate" hreflang="en" href={new URL(hreflang.en, Astro.site)} />
        <link rel="alternate" hreflang="x-default" href={new URL(hreflang.vi, Astro.site)} />
      </>
    )}
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta name="generator" content={Astro.generator} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={new URL(ogImage, Astro.site)} />
    <meta property="og:locale" content={lang === 'vi' ? 'vi_VN' : 'en_US'} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site)} />

    <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
    {isHome && <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />}
    {schema.map((s) => <script type="application/ld+json" set:html={JSON.stringify(s)} />)}

    <script async src="https://www.googletagmanager.com/gtag/js?id=G-Q3BPRDMPH9"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-Q3BPRDMPH9');
    </script>
  </head>
  <body class="min-h-screen">
    {!noChrome && <Header />}
    <main>
      <slot />
    </main>
    {!noChrome && <Footer />}
    {!noChrome && <MobileCTA />}
    <!-- Đếm bấm gọi / Zalo cho Google Ads. Tên event khớp cấu hình key event GA4
         và import conversion trong Google Ads — không đổi tên. -->
    <script is:inline define:vars={{ hotlineTels }}>
      document.addEventListener('click', (e) => {
        const a = e.target instanceof Element ? e.target.closest('a[href]') : null;
        if (!a || typeof gtag !== 'function') return;
        const href = a.getAttribute('href');
        if (href.startsWith('tel:')) {
          const num = href.slice(4).replace(/\D/g, '');
          gtag('event', hotlineTels.includes(num) ? 'click_hotline' : 'click_factory_phone', {
            phone_number: num,
          });
        } else if (href.includes('zalo.me')) {
          gtag('event', 'click_zalo');
        }
      });
    </script>
  </body>
</html>
