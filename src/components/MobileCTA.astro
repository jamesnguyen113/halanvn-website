---
import { site } from '../data/site';
---

<!-- Sticky quote bar: contractors call, they don't fill forms -->
<div class="fixed inset-x-0 bottom-0 z-50 grid grid-cols-3 border-t border-steel-200 bg-white shadow-[0_-2px_10px_rgba(20,23,28,0.12)] lg:hidden">
  <a
    href={`tel:${site.hotline.tel}`}
    class="display flex items-center justify-center gap-2 bg-brand py-3.5 text-sm tracking-wide text-white uppercase"
  >
    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M6.6 10.8a15.1 15.1 0 0 0 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C10.6 21 3 13.4 3 4c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.2.2 2.4.6 3.6.1.3 0 .7-.2 1l-2.3 2.2z" />
    </svg>
    Gọi ngay
  </a>
  <a
    href={site.zaloUrl}
    target="_blank"
    rel="noopener"
    class="display flex items-center justify-center gap-2 bg-[#0068ff] py-3.5 text-sm tracking-wide text-white uppercase"
  >
    Zalo
  </a>
  <a
    href="/bang-gia/"
    class="display flex items-center justify-center gap-2 bg-steel-950 py-3.5 text-sm tracking-wide text-white uppercase"
  >
    Bảng giá
  </a>
</div>
<!-- spacer so content isn't hidden behind the fixed bar -->
<div class="h-12 lg:hidden" aria-hidden="true"></div>
