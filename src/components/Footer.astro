---
import { site, locations, nav } from '../data/site';
import Corrugation from './Corrugation.astro';
const year = new Date().getFullYear();
---

<footer class="bg-steel-950 text-steel-300">
  <Corrugation class="h-5 w-full text-brand" />
  <div class="mx-auto grid max-w-6xl gap-10 px-4 py-12 sm:grid-cols-2 lg:grid-cols-3">
    <div>
      <p class="display text-lg text-white">{site.legalName}</p>
      <p class="mt-3 text-sm leading-relaxed">
        Sản xuất và cung cấp tôn lợp, xà gồ C — Z, sắt hộp, thép xây dựng từ năm {site.founded}.
        Có xe giao hàng tận nơi, xuất hóa đơn VAT.
      </p>
      <p class="mt-3 text-sm">{site.bank}</p>
    </div>

    <div>
      <p class="eyebrow mb-4 text-steel-400">Hệ thống nhà máy</p>
      <ul class="space-y-3 text-sm">
        {locations.map((l) => (
          <li>
            <span class="font-semibold text-steel-200">{l.name}</span>
            <br />
            {l.address}
          </li>
        ))}
      </ul>
    </div>

    <div>
      <p class="eyebrow mb-4 text-steel-400">Liên hệ</p>
      <ul class="text-sm tabular">
        {site.phones.map((p) => (
          <li>
            <a href={`tel:${p.tel}`} class="inline-block py-1.5 hover:text-white">
              <span class="text-steel-400">{p.label}:</span>
              {p.display}
            </a>
          </li>
        ))}
        <li>
          <a href={`mailto:${site.email}`} class="inline-block py-1.5 hover:text-white">{site.email}</a>
        </li>
      </ul>
      <ul class="mt-6 flex flex-wrap gap-x-4 gap-y-2 text-xs uppercase">
        {nav.map((item) => (
          <li><a href={item.href} class="hover:text-white">{item.label}</a></li>
        ))}
        <li><a href="/bao-mat/" class="hover:text-white">Bảo mật</a></li>
      </ul>
    </div>
  </div>
  <div class="border-t border-steel-800">
    <p class="mx-auto max-w-6xl px-4 py-4 text-xs text-steel-400">
      © {year} {site.legalName}. Bảng giá có thể thay đổi — vui lòng gọi {site.hotline.display} để được báo giá mới nhất.
    </p>
  </div>
</footer>
