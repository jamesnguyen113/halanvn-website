---
// Shared shell for the /san-pham/<category>/ landing pages: keyword H1,
// unique intro copy (slot), product grid, price CTA, Breadcrumb + ItemList schema.
import Base from '../layouts/Base.astro';
import ProductCard from './ProductCard.astro';
import { site } from '../data/site';
import { categories, byCategory } from '../data/products';

interface Props {
  categorySlug: string;
  title: string;
  description: string;
  /** H1 — the exact-match keyword phrase */
  heading: string;
  /** Short lead sentence under the H1 (hero) */
  lead: string;
}

const { categorySlug, title, description, heading, lead } = Astro.props;
const category = categories.find((c) => c.slug === categorySlug)!;
const items = byCategory(categorySlug);

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Trang chủ', item: new URL('/', Astro.site).href },
    { '@type': 'ListItem', position: 2, name: 'Sản phẩm', item: new URL('/san-pham/', Astro.site).href },
    { '@type': 'ListItem', position: 3, name: category.name },
  ],
};

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: category.name,
  itemListElement: items.map((p, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: p.name,
    url: new URL(`/san-pham/${p.slug}/`, Astro.site).href,
  })),
};
---

<Base title={title} description={description} schema={[breadcrumbSchema, itemListSchema]}>
  <div class="bg-steel-950 py-10 text-white">
    <div class="mx-auto max-w-6xl px-4">
      <nav class="text-xs text-steel-400" aria-label="Breadcrumb">
        <a href="/" class="hover:text-white">Trang chủ</a>
        <span aria-hidden="true"> / </span>
        <a href="/san-pham/" class="hover:text-white">Sản phẩm</a>
        <span aria-hidden="true"> / </span>
        <span class="text-steel-300">{category.name}</span>
      </nav>
      <h1 class="display mt-3 text-3xl sm:text-4xl">{heading}</h1>
      <p class="mt-3 max-w-2xl text-sm leading-relaxed text-steel-300">
        {lead}
        Gọi <a href={`tel:${site.hotline.tel}`} class="font-bold text-white underline">{site.hotline.display}</a>
        để được báo giá trong ngày.
      </p>
    </div>
  </div>

  <div class="mx-auto max-w-6xl px-4 py-10">
    <!-- Unique intro copy per category -->
    <section class="max-w-3xl space-y-3 text-[0.95rem] leading-relaxed text-steel-800">
      <slot />
    </section>

    {items.length > 0 && (
      <section class="mt-10">
        <h2 class="display border-l-4 border-brand pl-3 text-2xl text-steel-950">
          Sản phẩm {category.name.toLowerCase()}
        </h2>
        <div class="mt-6 grid grid-cols-2 gap-3 sm:gap-5 lg:grid-cols-4">
          {items.map((p) => <ProductCard product={p} />)}
        </div>
      </section>
    )}

    <div class="mt-12 border-l-4 border-brand bg-steel-50 p-5">
      <p class="display text-lg text-steel-950">Giá theo ngày — gọi để chốt</p>
      <p class="mt-1 text-sm text-steel-700">
        Giá tôn thép thay đổi theo thị trường. Xem <a href="/bang-gia/" class="text-brand underline">bảng giá tham khảo</a>
        hoặc gọi hotline để có giá tốt nhất hôm nay, đã gồm VAT.
      </p>
      <div class="mt-4 flex flex-wrap gap-3">
        <a
          href={`tel:${site.hotline.tel}`}
          class="display bg-brand px-5 py-3 text-sm tracking-widest text-white uppercase hover:bg-brand-hot"
        >
          {site.hotline.display}
        </a>
        <a
          href={site.zaloUrl}
          target="_blank"
          rel="noopener"
          class="display border border-steel-950 px-5 py-3 text-sm tracking-widest text-steel-950 uppercase hover:bg-steel-950 hover:text-white"
        >
          Nhắn Zalo
        </a>
      </div>
    </div>
  </div>
</Base>
