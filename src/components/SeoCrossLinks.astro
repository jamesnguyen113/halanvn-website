---
// Khối "Xem thêm" dùng chung cho các trang giá / thương hiệu / danh mục —
// mỗi trang tiền (money page) liên kết tới toàn bộ trang anh em còn lại.
interface Props {
  /** pathname của trang hiện tại (bị loại khỏi danh sách), ví dụ '/ton-dong-a/' */
  current: string;
}

const links = [
  { href: '/bang-gia/', label: 'Bảng giá tôn lợp, xà gồ hôm nay' },
  { href: '/bang-gia/ton-lop/', label: 'Bảng giá tôn lợp mới nhất' },
  { href: '/bang-gia/xa-go/', label: 'Báo giá xà gồ C — Z' },
  { href: '/ton-hoa-sen/', label: 'Tôn Hoa Sen chính hãng' },
  { href: '/ton-dong-a/', label: 'Tôn Đông Á — giá hôm nay' },
  { href: '/ton-nam-kim/', label: 'Tôn Nam Kim chính hãng' },
  { href: '/san-pham/ton-lop/', label: 'Sản phẩm tôn lợp — các loại sóng' },
  { href: '/san-pham/ton-cach-nhiet/', label: 'Tôn cách nhiệt PE' },
  { href: '/san-pham/xa-go/', label: 'Xà gồ C — Z cán theo quy cách' },
  { href: '/thep-hop/', label: 'Thép hộp, sắt hộp — đủ quy cách' },
];

const { current } = Astro.props;
const show = links.filter((l) => l.href !== current);
---

<section class="mt-12 max-w-3xl">
  <h2 class="display border-l-4 border-brand pl-3 text-xl text-steel-950">Xem thêm</h2>
  <ul class="mt-3 grid gap-x-6 gap-y-1.5 text-sm sm:grid-cols-2">
    {show.map((l) => (
      <li>
        <a href={l.href} class="text-brand underline">{l.label}</a>
      </li>
    ))}
  </ul>
</section>
